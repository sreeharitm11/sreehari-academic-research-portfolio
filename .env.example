# Resend API Key for serverless contact form
# Get one for free at: https://resend.com
RESEND_API_KEY=re_your_api_key_here

# Contact Form Receiver Email (where portfolio messages will be sent)
# Defaults to sreeharitm11@gmail.com if left blank
CONTACT_RECEIVER_EMAIL=sreeharitm11@gmail.com

# Google Analytics 4 (GA4) Measurement ID
# Should start with G-
VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Sanity CMS Configuration
# Get these from your Sanity manage project dashboard: https://sanity.io/manage
VITE_SANITY_PROJECT_ID=your_sanity_project_id_here
VITE_SANITY_DATASET=production
